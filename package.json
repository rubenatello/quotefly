{
  "name": "quotefly",
  "version": "1.0.0",
  "description": "QuoteFly backend-first API platform for contractor quote automation",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "npm --prefix web run dev",
    "dev:web:host": "npm --prefix web run dev -- --host",
    "dev:all": "concurrently -k -n API,WEB,DB \"npm run dev:api\" \"npm run dev:web\" \"npm run prisma:studio\"",
    "eval:ai": "tsx scripts/ai-quote-eval.ts --mode=parser",
    "eval:ai:model": "tsx scripts/ai-quote-eval.ts --mode=ai",
    "build": "tsc -p tsconfig.json",
    "build:web": "npm --prefix web run build",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "start:prod": "npm run prisma:migrate:deploy && node dist/server.js",
    "prisma:studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^6.19.3",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "fastify-raw-body": "^5.0.0",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.0.0",
    "twilio": "^5.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
